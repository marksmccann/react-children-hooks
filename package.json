{
    "name": "react-children-hooks",
    "version": "0.7.1",
    "description": "React hooks for inspecting, traversing, querying, and validating props.children.",
    "keywords": [
        "react",
        "children",
        "hooks",
        "components",
        "typescript"
    ],
    "homepage": "https://github.com/marksmccann/react-children-hooks#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/marksmccann/react-children-hooks.git"
    },
    "bugs": {
        "url": "https://github.com/marksmccann/react-children-hooks/issues"
    },
    "license": "MIT",
    "author": "Mark McCann",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./*": null
    },
    "files": [
        "dist",
        "llms.txt"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsup",
        "commit": "cz",
        "dev": "tsup --watch",
        "format": "prettier --write .",
        "lint": "eslint .",
        "prepublishOnly": "npm run build",
        "release": "release-it",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.0",
        "@commitlint/config-conventional": "^19.8.0",
        "@eslint/js": "^9.27.0",
        "@release-it/conventional-changelog": "^10.0.2",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^22.15.30",
        "@types/react": "^19.1.5",
        "@vitest/coverage-v8": "^3.1.4",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.1.0",
        "husky": "^9.1.7",
        "jsdom": "^26.1.0",
        "lint-staged": "^15.5.2",
        "prettier": "^3.5.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "release-it": "^19.0.4",
        "tsup": "^8.5.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1",
        "vitest": "^3.1.4"
    },
    "dependencies": {
        "runtime-reporter": "^0.10.0"
    }
}
